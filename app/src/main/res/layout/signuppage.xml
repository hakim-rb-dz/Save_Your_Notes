<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingHorizontal="15dp"
    tools:context=".singupActivity">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="200dp"
        android:layout_height="250dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/notelogo"
        tools:layout_editor_absoluteY="-11dp" />

    <EditText
        android:id="@+id/UseName..."
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:layout_marginStart="20dp"

        android:layout_marginTop="328dp"
        android:background="@drawable/input_style"
        android:drawableEnd="@android:drawable/checkbox_on_background"
        android:drawablePadding="20dp"
        android:ems="10"
        android:inputType="text"
        android:paddingHorizontal="15dp"
        android:text="Usename..."
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.163"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/signuppassword"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:background="@drawable/input_style"
        android:drawableEnd="@android:drawable/ic_lock_lock"
        android:text="Passwod..."
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="395dp" />

    <Button
        android:id="@+id/signupburron"
        android:layout_width="150dp"
        android:layout_height="51dp"
        android:background="@drawable/input_style"
        android:text="Login "
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.411"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="463dp" />

    <EditText
        android:id="@+id/msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawablePadding="50dp"
        android:ems="10"
        android:inputType="text"
        android:text="          or"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="503dp" />

    <Button
        android:id="@+id/signupbutton"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:text="signup with google "
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="556dp" />

    <Button
        android:id="@+id/facebookbutton"
        android:layout_width="300dp"
        android:layout_height="50dp"
        android:text="signup with facebook"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="617dp" />

    <TextView
        android:id="@+id/signuppage"
        android:layout_width="250dp"
        android:layout_height="50dp"
        android:text="signup page "
        android:textColor="@color/orange"
        android:textSize="34sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="55dp"
        tools:layout_editor_absoluteY="240dp" />

    <TextView
        android:id="@+id/return_button"
        android:layout_width="150dp"
        android:layout_height="50dp"
        android:drawableEnd="@android:drawable/ic_menu_revert"
        android:text="    return"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="245dp"
        tools:layout_editor_absoluteY="667dp" />


</androidx.constraintlayout.widget.ConstraintLayout>